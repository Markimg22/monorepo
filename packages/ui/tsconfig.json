{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@monorepo/typescript-config/react.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["@testing-library/jest-dom/vitest"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
